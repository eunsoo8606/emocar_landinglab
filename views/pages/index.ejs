  <!-- 수출 시세 비교 리포트 섹션 -->
  <section id="compare" class="compare-section">
    <div class="section-container">
      <div class="section-header">
        <h2 class="section-title">내수 처분 대비 압도적인 혜택 비교</h2>
        <p class="section-subtitle">연식이 오래되고 사고가 났더라도, 해외 시장에서는 가치 평가 기준이 달라 최고의 견적을 받으실 수 있습니다.</p>
      </div>

      <div class="compare-rows">
        <!-- 첫 번째 행: 주행거리 비교 -->
        <div class="compare-row">
          <!-- 좌: 그래프 카드 -->
          <div class="compare-card graph-card">
            <div class="card-inner">
              <div class="compare-badge-wrapper">
                <span class="compare-badge">주행거리 15만 km 이상 노후 차량</span>
              </div>
              <h3 class="compare-price-title">평균 <span class="highlight-text">200만 원</span> 이상 추가 보상</h3>
              <p class="compare-price-subtitle">수출 거래에서는 주행거리로 인한 무자비한 감가가 없습니다.</p>

              <div class="graph-container">
                <div class="graph-grid-lines">
                  <span></span>
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <div class="graph-bars">
                  <div class="bar-wrapper">
                    <div class="bar-label-top">평균 550만~600만</div>
                    <div class="graph-bar-bg">
                      <div class="graph-bar bar-korea" style="height: 70%;"></div>
                    </div>
                    <div class="bar-label-bottom">국내 딜러가</div>
                  </div>
                  <div class="bar-wrapper">
                    <div class="bar-label-top highlight-price">최대 800만 원</div>
                    <div class="graph-bar-bg">
                      <div class="graph-bar bar-export" style="height: 100%;"></div>
                    </div>
                    <div class="bar-label-bottom highlight-price-bottom">이모카 수출가</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 우: 설명 카드 -->
          <div class="compare-card info-card">
            <div class="card-content">
              <h3 class="info-title">주행거리가 많아 고민하셨나요?</h3>
              <p class="info-desc">
                해외 시장 바이어들은 계기판의 숫자보다 **엔진 성능, 미션 상태, 골격 상태**를 우선 평가합니다. 국내에서는 주행거리가 15만~20만 km만 넘어도 폐차 취급을 받지만, 이모카와 함께라면 높은 잔존 가치를 그대로 돌려받을 수 있습니다.
              </p>
            </div>
          </div>
        </div>

        <!-- 두 번째 행: 사고이력 비교 -->
        <div class="compare-row reverse">
