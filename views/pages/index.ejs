<%- include('../partials/header') %>

  <!-- 히어로 섹션 (소개 및 폼, 모던 미니멀 배경) -->
  <section class="hero-section">
    <div class="hero-bg-overlay"></div>
    <div class="hero-container">
      <div class="hero-grid">
        <!-- 좌측 소개란 (이모카 컨셉 반영) -->
        <div class="hero-text-area">
          <span class="hero-badge">TRUSTED USED CAR EXPORT</span>
          <h1 class="hero-title">이모처럼 친근하게,<br>내 차 값은 <span class="highlight-text">최고가로!</span></h1>
          <p class="hero-subtitle">
            여성 대표가 운영하여 더욱 <strong>투명하고 정직한 이모카</strong>입니다.<br>
            주행거리가 많아도, 연식이 오래되어도 감가 걱정 없이 내수 딜러가 대비 <strong>최대 300만 원 더</strong> 받는 해외 직수출 시세를 지금 확인해보세요.
          </p>

          <div class="hero-features-list">
            <div class="h-feature-item">
              <span class="h-feature-icon"><i class="fa-solid fa-check"></i></span>
              여성 대표의 섬세함으로 <strong>100% 감가 없는 정직한 견적</strong>
            </div>
            <div class="h-feature-item">
              <span class="h-feature-icon"><i class="fa-solid fa-check"></i></span>
              귀찮은 행정 서류부터 구청 말소 등록까지 <strong>당일 즉시 완료</strong>
            </div>
            <div class="h-feature-item">
              <span class="h-feature-icon"><i class="fa-solid fa-check"></i></span>
              전국 어디든 찾아가는 <strong>무료 출장 감정 및 수수료 Zero</strong>
            </div>
          </div>
        </div>

        <!-- 우측 견적 및 무료 상담 신청 폼 -->
        <div class="hero-form-area">
          <div class="form-wrapper">
            <div class="form-header">
              <h3>간편 1분 견적 신청</h3>
              <p>이모카와 함께하는 내 차 수출 시세 조회</p>
            </div>
            <form id="heroQuoteForm" class="quote-form">
              <div class="form-group">
                <label for="car-model">차량명 <span class="required">*</span></label>
                <input type="text" id="car-model" name="carModel" placeholder="ex) 아반떼 AD, 쏘렌토 R, 스포티지" required>
              </div>

              <div class="form-group">
                <label for="phone">연락처 <span class="required">*</span></label>
                <div class="phone-inputs">
                  <input type="tel" name="phone1" value="010" maxlength="3" required>
                  <span>-</span>
                  <input type="tel" name="phone2" placeholder="0000" maxlength="4" required>
                  <span>-</span>
                  <input type="tel" name="phone3" placeholder="0000" maxlength="4" required>
                </div>
              </div>

              <div class="form-group">
                <label for="mileage">주행거리 (키로수) <span class="required">*</span></label>
                <select id="mileage" name="mileage" required>
                  <option value="" disabled selected>주행거리를 선택하세요</option>
                  <option value="10만km 이하">10만 km 이하</option>
                  <option value="10만~20만km">10만 ~ 20만 km</option>
                  <option value="20만km 이상">20만 km 이상 (수출 강력 추천)</option>
                </select>
              </div>

              <div class="form-group">
                <label for="car-year">차량 연식</label>
                <input type="text" id="car-year" name="carYear" placeholder="ex) 2015년식">
              </div>

              <div class="form-agreement">
                <label class="agreement-label">
                  <input type="checkbox" name="agree" checked required>
                  <span>개인정보 수집 및 이용 동의 (필수)</span>
                </label>
              </div>

              <button type="submit" class="btn-form-submit">
                <span>1분 만에 내 차 견적 확인하기 <i class="fa-solid fa-angle-right"></i></span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 혜택 하이라이트 띠 바 (이모카 테마) -->
  <section class="highlight-bar-section">
    <div class="highlight-bar-container">
      <div class="hl-item">
        <span class="hl-icon"><i class="fa-solid fa-phone"></i></span>
        <span class="hl-text">상담부터 출장까지<br><strong>100% 전과정 무료 진행</strong></span>
      </div>
      <div class="hl-item">
        <span class="hl-icon"><i class="fa-solid fa-car"></i></span>
        <span class="hl-text">주행거리가 아무리 많아도<br><strong>키로수 감가 없이 견적 보장</strong></span>
      </div>
      <div class="hl-item">
        <span class="hl-icon"><i class="fa-solid fa-wrench"></i></span>
        <span class="hl-text">노후 차량 / 사고 차량도<br><strong>폐차 가격 이상 무조건 OK</strong></span>
      </div>
      <div class="hl-item">
        <span class="hl-icon"><i class="fa-solid fa-shield-halved"></i></span>
        <span class="hl-text">정직과 신뢰 최우선<br><strong>당일 100% 송금 및 완벽 말소</strong></span>
      </div>
    </div>
  </section>

  <!-- 이모카의 가치 & 특징 섹션 (여성 대표 신뢰감 소구) -->
  <section id="features" class="features-section">
    <div class="section-container">
      <div class="section-header">
        <h2 class="section-title">왜 중고차 해외 수출은 <span class="highlight-text">이모카</span>일까요?</h2>
        <p class="section-subtitle">삭막하고 불안했던 중고차 거래, 여성 대표가 직접 섬세하고 신뢰할 수 있게 운영하는 이모카에서 기분 좋게 마무리하세요.</p>
      </div>

      <div class="features-grid">
        <!-- 특장점 1 -->
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-heart-circle-check"></i></div>
          <h3 class="feature-title">여성 대표의 안심 비즈니스</h3>
          <p class="feature-desc">과장된 감가, 부당한 트집 잡기를 전면 배제했습니다. 여성 대표가 내 차를 처분한다는 마음으로 투명하고 정직하게 1:1 전담 마크해 드립니다.</p>
        </div>
        <!-- 특장점 2 -->
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-sack-dollar"></i></div>
          <h3 class="feature-title">해외 바이어 다이렉트 최고가</h3>
          <p class="feature-desc">국내 내수 시장의 딜러 마진, 상사 수수료 등 불필요한 유통 구조를 전면 생략하여 해외 바이어 가격 그대로 가장 높은 금액을 챙겨 드립니다.</p>
        </div>
        <!-- 특장점 3 -->
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-clipboard-check"></i></div>
          <h3 class="feature-title">당일 즉시 송금 & 말소 완료</h3>
          <p class="feature-desc">계약서 작성 후 현장에서 100% 대금 즉시 송금은 물론, 구청 말소 대행 절차를 당일 완료하여 자동차세 및 보험 걱정을 깔끔하게 털어 드립니다.</p>
        </div>
      </div>
    </div>
  </section>

