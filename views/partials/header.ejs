  <link rel="icon" href="/images/logo/favicon.png" type="image/png" sizes="192x192">
  <link rel="apple-touch-icon" href="/images/logo/favicon.png">

  <!-- Open Graph -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : '이모카 중고차 해외 수출' %>">
  <meta property="og:description" content="여성 대표가 정직하게 운영하는 중고차 해외 수출 전문 브랜드 이모카! 감가 없이 최대 300만원 더 받는 비결을 확인하세요.">
  <meta property="og:image" content="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://emocar.co.kr' %>/images/meta-image.png">
  <meta property="og:url" content="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://emocar.co.kr' %>/">
  <meta property="og:type" content="website">

