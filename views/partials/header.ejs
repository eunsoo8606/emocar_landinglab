  <!-- 네이버 서치어드바이저 소유권 확인 (필요시 교체) -->
  <meta name="naver-site-verification" content="67604072c4c775d33b8e2b7fff43fb1bfd38c5c9" />

  <!-- 대표 URL 설정 -->
  <link rel="canonical" href="https://emocar.co.kr/">
  <link rel="alternate" type="application/rss+xml" title="이모카 중고차수출 RSS Feed" href="https://emocar.co.kr/rss.xml">

  <!-- 파비콘 설정 -->
