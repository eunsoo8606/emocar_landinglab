  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : '이모카 중고차 해외 수출' %>">
  <meta name="twitter:description" content="여성 대표가 정직하게 운영하는 중고차 해외 수출 전문 브랜드 이모카! 감가 없이 최대 300만원 더 받는 비결을 확인하세요.">
  <meta name="twitter:image" content="<%= typeof baseUrl !== 'undefined' ? baseUrl : 'https://emocar.co.kr' %>/images/meta-image.png">

