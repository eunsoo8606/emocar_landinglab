    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "마마 트레이딩 (이모카)",
    "image": "https://emocar.co.kr/images/logo/logo.png",
    "@id": "https://emocar.co.kr/#website",
    "url": "https://emocar.co.kr/",
    "telephone": "010-2995-2332",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "서부대로 264-3, 3층 301-3047호",
      "addressLocality": "Cheonan",
      "addressRegion": "Chungcheongnam-do",
      "postalCode": "31156",
      "addressCountry": "KR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 36.7869,
      "longitude": 127.1332
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "opens": "00:00",
      "closes": "23:59"
    },
    "sameAs": [
      "https://blog.naver.com/qqodzh11"
    ]
  }
  </script>

  <!-- 프리미엄 서체 로드 (Outfit & Noto Sans KR) -->
